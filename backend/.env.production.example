# ================================================================
# RELAC 2026 — Configuration Production
# ================================================================
# INSTRUCTIONS :
# 1. Copier ce fichier et le renommer en ".env"
# 2. Remplir TOUTES les valeurs (les vides sont obligatoires)
# 3. Ne JAMAIS committer le fichier .env sur Git !
# ================================================================

# ─────────────────────────────────────────────
# SERVEUR
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─────────────────────────────────────────────
# SÉCURITÉ JWT
# Générer une clé forte avec :
#   node -e "const c=require('crypto'); console.log(c.randomBytes(64).toString('hex'));"
# ─────────────────────────────────────────────
JWT_SECRET=REMPLACER_PAR_UNE_CLE_SECRETE_FORTE_DE_64_CARACTERES_MINIMUM
JWT_EXPIRE=7d

# ─────────────────────────────────────────────
# FRONTEND
# URL publique de ton site (sans slash final)
# Exemples :
#   https://relac2026.netlify.app
#   https://relac2026.com
# ─────────────────────────────────────────────
FRONTEND_URL=https://relac2026.netlify.app

# ─────────────────────────────────────────────
# EMAIL — Configuration Gmail (SMTP)
# ─────────────────────────────────────────────
# ÉTAPES pour configurer Gmail :
# 1. Aller sur myaccount.google.com
# 2. Sécurité → Validation en deux étapes (activer)
# 3. Sécurité → Mots de passe des applications
# 4. Créer un mot de passe pour "Autre (nom personnalisé)" → "ReLAc 2026"
# 5. Copier le mot de passe à 16 caractères généré ci-dessous
# ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=jonathanlubaki7@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=ReLAc 2026 <jonathanlubaki7@gmail.com>

# ─────────────────────────────────────────────
# UPLOAD DE FICHIERS
# ─────────────────────────────────────────────
MAX_FILE_SIZE=5242880
